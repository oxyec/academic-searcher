# Copy this file to .env and fill in your values.
# The app works without any keys, but providing them improves quality and rate limits.

# Contact email sent to Unpaywall and Crossref for API politeness.
# Highly recommended to avoid being throttled.
UNPAYWALL_EMAIL=your_email@example.com

# Semantic Scholar API key (optional) – raises the rate limit significantly.
S2_API_KEY=

# Google Custom Search credentials (both required to enable the Google source).
GOOGLE_API_KEY=
CSE_ID=

# Set to "true" to persist saved searches and bookmarks to .academic_search_state.json.
# Keep this "false" on shared/cloud deployments to avoid cross-user state leakage.
ACADEMIC_SEARCH_PERSIST_STATE=false
